# LeadGen LA — Environment Variables
# Copy this file to .env and fill in your API keys

# Google Places API (New) — used for business search and details
# https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# SerpAPI — used for ad presence and competitor detection
# https://serpapi.com/manage-api-key
SERP_API_KEY=your_serp_api_key_here

# Apollo.io Organizations Enrich API — used for owner contact enrichment
# https://developer.apollo.io/
APOLLO_API_KEY=your_apollo_api_key_here

# Server port (optional, defaults to 5000)
PORT=5000
